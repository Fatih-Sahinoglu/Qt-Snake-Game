             <widget class="QPushButton" name="Start_btn">
              <property name="styleSheet">
               <string notr="true">QPushButton {
    /* Normal Hali: Yılan Yeşili */
    background-color: #4CAF50; 
    color: white;
    border-radius: 10px;
    border: 2px solid #2E7D32;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 16px;
    font-weight: bold;
    padding: 8px;
    /* Hafif gölge efekti */
    border-bottom: 4px solid #1B5E20; 
}

QPushButton:hover {
    /* Hover: Biraz daha açık, parlak bir yeşil */
    background-color: #66BB6A;
    border-color: #388E3C;
}

QPushButton:pressed {
    /* Basılma: Koyu yeşil ve butonu aşağı çekme efekti */
    background-color: #2E7D32;
    border-bottom: 1px solid #1B5E20; /* Gölge azalır */
    margin-top: 3px; /* Buton aşağı iner (basma hissi) */
}</string>
              </property>
